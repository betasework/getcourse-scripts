<textarea id="rawStatThemeCode" style="display:none;">$(document).ready(function(){
  if(location.href.indexOf('/teach/control/stream/stat/id/')===-1)return;
  function heat(pct){return pct>=70?'#EAF3DE':pct>=40?'#FEF3CD':'#FCEBEB';}
  function miniBar(pct,col){return '<span style="display:inline-block;width:36px;height:6px;background:#e0e0e0;border-radius:3px;vertical-align:middle;margin-right:5px"><span style="display:block;width:'+Math.min(pct,100)+'%;height:100%;background:'+col+';border-radius:3px"></span></span>';}
  function runStats(){
    var table=document.querySelector('table');
    if(!table)return;
    var thead=table.querySelector('thead tr');
    if(!thead)return;
    var ths=thead.querySelectorAll('th');
    var visitedIdx=-1,answeredIdx=-1,passedIdx=-1,lessonIdx=0,statusIdx=-1;
    ths.forEach(function(th,i){var t=th.textContent.trim();if(t==='Зашли')visitedIdx=i;if(t==='Ответили')answeredIdx=i;if(t==='Прошли')passedIdx=i;if(t==='Статус')statusIdx=i;});
    if(visitedIdx===-1)return;
    var rows=Array.prototype.slice.call(table.querySelectorAll('tbody tr'));
    var maxV=0;
    rows.forEach(function(r){var tds=r.querySelectorAll('td');if(tds[visitedIdx]){var v=parseInt(tds[visitedIdx].textContent)||0;if(v>maxV)maxV=v;}});
    if(maxV===0)return;
    if(!thead.querySelector('th.gc-st')){
      [['% Зашли','#185FA5'],['Δ отвал','#6b6b6b'],['% ДЗ','#8B5CF6'],['% Прошли','#27500A']].forEach(function(pair){
        var th=document.createElement('th');th.className='gc-st';th.textContent=pair[0];
        th.style.cssText='text-align:center;white-space:nowrap;padding:4px 10px;font-size:13px;color:'+pair[1]+';font-weight:600;';
        thead.appendChild(th);
      });
    }
    var prev=null;
    var csvData=[['Урок','Статус','Зашли','Ответили','Прошли','% Зашли','Δ отвал','% ДЗ','% Прошли']];
    rows.forEach(function(row){
      if(row.querySelector('td.gc-st'))return;
      var tds=row.querySelectorAll('td');if(!tds[visitedIdx])return;
      var lessonName=(tds[lessonIdx]?(tds[lessonIdx].querySelector('a')||tds[lessonIdx]).textContent.trim():'');
      var statusTxt=statusIdx!==-1&&tds[statusIdx]?tds[statusIdx].textContent.trim():'';
      var v=parseInt(tds[visitedIdx].textContent)||0;
      var a=answeredIdx!==-1?(parseInt(tds[answeredIdx].textContent)||0):0;
      var p=passedIdx!==-1?(parseInt(tds[passedIdx].textContent)||0):0;
      var pV=Math.round(v*100/maxV);
      var pA=v>0?Math.round(a*100/v):0;
      var pP=Math.round(p*100/maxV);
      var delta=prev!==null?v-prev:null;
      var dStr=delta===null?'—':(delta===0?'0':(delta>0?'+'+delta:''+delta));
      var dCol=delta===null?'#888':delta<-5?'#A32D2D':delta<0?'#BA7517':'#3B6D11';
      [[visitedIdx,'#185FA5'],[answeredIdx,'#8B5CF6'],[passedIdx,'#27500A']].forEach(function(pair){
        if(pair[0]===-1)return;var td=tds[pair[0]];if(!td)return;
        var pct=Math.round((parseInt(td.textContent)||0)*100/maxV);
        td.style.background=heat(pct);
      });
      [
        '<td class="gc-st" style="text-align:center;padding:4px 10px;background:'+heat(pV)+'">'+miniBar(pV,'#185FA5')+'<span style="font-size:12px;font-weight:600">'+pV+'%</span></td>',
        '<td class="gc-st" style="text-align:center;padding:4px 10px;font-size:12px;font-weight:600;color:'+dCol+'">'+dStr+'</td>',
        '<td class="gc-st" style="text-align:center;padding:4px 10px;background:'+heat(pA)+'">'+miniBar(pA,'#8B5CF6')+'<span style="font-size:12px;font-weight:600">'+pA+'%</span></td>',
        '<td class="gc-st" style="text-align:center;padding:4px 10px;background:'+heat(pP)+'">'+miniBar(pP,'#27500A')+'<span style="font-size:12px;font-weight:600">'+pP+'%</span></td>'
      ].forEach(function(h){var tmp=document.createElement('tbody');tmp.innerHTML='<tr>'+h+'</tr>';row.appendChild(tmp.querySelector('td'));});
      csvData.push([lessonName,statusTxt,v,a,p,pV+'%',dStr,pA+'%',pP+'%']);
      prev=v;
    });
    var oldCsv=document.getElementById('gc-stat-csv');if(oldCsv)oldCsv.remove();
    var csvBtn=document.createElement('button');csvBtn.id='gc-stat-csv';
    csvBtn.textContent='Скачать CSV';
    csvBtn.style.cssText='margin:14px 0 4px;padding:8px 18px;background:#185FA5;color:#fff;border:none;border-radius:6px;font-size:14px;cursor:pointer;font-family:sans-serif;';
    csvBtn.onclick=function(){
      var csv=csvData.map(function(r){return r.map(function(c){return '"'+String(c).replace(/"/g,'""')+'"';}).join(',');}).join('\n');
      var a=document.createElement('a');
      a.href='data:text/csv;charset=utf-8,\uFEFF'+encodeURIComponent(csv);
      a.download='lesson_stat_'+new Date().toISOString().slice(0,10)+'.csv';
      a.click();
    };
    var df=document.getElementById('gc-stat-df');
    if(df)df.appendChild(csvBtn);else table.parentNode.insertBefore(csvBtn,table);
  }
  function applyFilter(urlStr){
    var applyBtn=document.getElementById('gc-df-apply');
    var resetBtn=document.getElementById('gc-df-reset');
    if(applyBtn){applyBtn.textContent='Загрузка…';applyBtn.disabled=true;}
    if(resetBtn)resetBtn.disabled=true;
    $.get(urlStr,function(html){
      var newTable=$($.parseHTML(html)).find('table').first()[0]||$(html).filter('table')[0];
      if(!newTable)newTable=(new DOMParser()).parseFromString(html,'text/html').querySelector('table');
      var curTable=document.querySelector('table');
      if(newTable&&curTable){curTable.parentNode.replaceChild(newTable,curTable);}
      history.pushState({},'',urlStr);
      if(applyBtn){applyBtn.textContent='Применить';applyBtn.disabled=false;}
      if(resetBtn)resetBtn.disabled=false;
      runStats();
    }).fail(function(){location.href=urlStr;});
  }
  if(!document.getElementById('gc-stat-df')){
    var params=new URLSearchParams(location.search);
    var dFrom=params.get('date_from')||'';
    var dTo=params.get('date_to')||'';
    var bar=document.createElement('div');
    bar.id='gc-stat-df';
    bar.style.cssText='display:flex;align-items:center;gap:10px;margin:10px 0 16px;font-family:sans-serif;font-size:13px;flex-wrap:wrap;padding:10px 14px;background:#F0F6FF;border-radius:8px;border:1px solid #C8DCF5;';
    bar.innerHTML='<span style="font-weight:600;color:#185FA5">Фильтр по дате входа:</span>'
      +'<label style="color:#555">с <input type="date" id="gc-df-from" value="'+dFrom+'" style="margin-left:4px;padding:3px 7px;border:1px solid #ccc;border-radius:4px;font-size:13px;"></label>'
      +'<label style="color:#555">по <input type="date" id="gc-df-to" value="'+dTo+'" style="margin-left:4px;padding:3px 7px;border:1px solid #ccc;border-radius:4px;font-size:13px;"></label>'
      +'<button id="gc-df-apply" style="padding:4px 14px;background:#185FA5;color:#fff;border:none;border-radius:4px;font-size:13px;cursor:pointer;font-family:sans-serif;">Применить</button>'
      +'<button id="gc-df-reset" style="padding:4px 10px;background:#eee;color:#555;border:none;border-radius:4px;font-size:13px;cursor:pointer;font-family:sans-serif;">Сбросить</button>';
    var ref=document.querySelector('.container-fluid,.content,.page-header,h2,h1');
    if(ref)ref.parentNode.insertBefore(bar,ref);
    else document.body.prepend(bar);
    document.getElementById('gc-df-apply').onclick=function(){
      var f=document.getElementById('gc-df-from').value;
      var t=document.getElementById('gc-df-to').value;
      var url=new URL(location.href);
      if(f)url.searchParams.set('date_from',f);else url.searchParams.delete('date_from');
      if(t)url.searchParams.set('date_to',t);else url.searchParams.delete('date_to');
      applyFilter(url.toString());
    };
    document.getElementById('gc-df-reset').onclick=function(){
      var url=new URL(location.href);
      url.searchParams.delete('date_from');url.searchParams.delete('date_to');
      applyFilter(url.toString());
    };
  }
  runStats();
});</textarea>


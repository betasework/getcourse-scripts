  <div class="tabs">
    <button class="tab-btn active" onclick="switchStatTab('stat-theme', this)">⚙️ Через тему аккаунта</button>
    <button class="tab-btn" onclick="switchStatTab('stat-bookmark', this)">🔖 Закладка в браузере</button>
  </div>

  <div class="tab-panel active" id="tab-stat-theme">
    <p style="font-size:14px;color:var(--muted);margin-bottom:20px;line-height:1.6;">Если скрипт Учеников уже установлен через тему — <b style="color:var(--ink)">дополни тот же JS файл</b> этим кодом снизу. Он работает на другом URL и не будет конфликтовать.</p>
    <div class="theme-code-wrap">
      <div class="theme-code-label">Код для вставки в JS темы (добавить после существующего кода)</div>
      <div class="theme-code-area" id="statThemeCodeArea">загрузка...</div>
      <button class="copy-btn" onclick="copyStatThemeCode()">Скопировать код <span class="copied-msg" id="statThemeCopiedMsg">✓ скопировано</span></button>
    </div>
    <div class="note" style="margin-top:16px;">
      <b>Страница:</b> работает только на <code>/teach/control/stream/stat/id/...</code> (вкладка «Статистика» потока) и не затрагивает другие страницы.
    </div>
  </div>

  <div class="tab-panel" id="tab-stat-bookmark">
    <p style="font-size:14px;color:var(--muted);margin-bottom:20px;line-height:1.6;">Отдельная закладка для страницы Статистики. Открой вкладку «Статистика» любого потока и кликни закладку.</p>
    <div class="bookmark-wrap">
      <div class="bookmark-label">Перетащи кнопку в панель закладок браузера</div>
      <a id="statBmBtn" class="bookmark-btn" href="#" style="background:linear-gradient(135deg,#6D28D9,#4C1D95);">📈 LessonStat</a>
      <div class="bookmark-arrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6b6b6b" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        Перетащи сюда, в панель закладок
      </div>
    </div>
    <div class="manual" style="margin-top:16px;">
      <div class="manual-header" onclick="toggleStatManual(this)">
        Не получается перетащить? Установи вручную
        <svg class="manual-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b6b6b" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
      </div>
      <div class="manual-body" id="statManualBody">
        <p>Правая кнопка на панели закладок → <b>«Добавить страницу»</b> → в поле <b>URL</b> вставь код ниже → сохрани.</p>
        <div class="code-area" id="statCodeArea">загрузка...</div>
        <button class="copy-btn" onclick="copyStatCode()">Скопировать код <span class="copied-msg" id="statCopiedMsg">✓ скопировано</span></button>
      </div>
    </div>
  </div>

</div>

<script>
function setupInstructions() {
  var rawCode = document.getElementById('rawBookmarklet').value.trim();
  var THEME_CODE = document.getElementById('rawThemeCode').value.trim();

  // Формируем корректный javascript: URL через encodeURIComponent
  // Это гарантирует правильную передачу одинарных кавычек и всех спецсимволов
  var bookmarkletHref = 'javascript:' + encodeURIComponent(rawCode);

  var bmBtn = document.getElementById('bmBtn');
  var codeArea = document.getElementById('codeArea');
  if (bmBtn) bmBtn.href = bookmarkletHref;
  if (codeArea) codeArea.textContent = bookmarkletHref;

  var themeCodeArea = document.getElementById('themeCodeArea');
  if (themeCodeArea) themeCodeArea.textContent = THEME_CODE;
}

function copyCode() {
  var rawCode = document.getElementById('rawBookmarklet').value.trim();
  var bookmarkletHref = 'javascript:' + encodeURIComponent(rawCode);
  navigator.clipboard.writeText(bookmarkletHref).then(function() {
    var msg = document.getElementById('copiedMsg');
    msg.style.opacity = '1';
    setTimeout(function() { msg.style.opacity = '0'; }, 2000);
  });
}

function copyThemeCode() {
  var code = document.getElementById('rawThemeCode').value.trim();
  navigator.clipboard.writeText(code).then(function() {
    var msg = document.getElementById('themecopiedMsg');
    msg.style.opacity = '1';
    setTimeout(function() { msg.style.opacity = '0'; }, 2000);
  });
}

function switchTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
}

function toggleManual(header) {
  var body = document.getElementById('manualBody');
  var chevron = header.querySelector('.manual-chevron');
  body.classList.toggle('open');
  if (chevron) chevron.style.transform = body.classList.contains('open') ? 'rotate(180deg)' : '';
}

function setupStatInstructions() {
  var rawCode = document.getElementById('rawStatBookmarklet').value.trim();
  var themeCode = document.getElementById('rawStatThemeCode').value.trim();
  var bookmarkletHref = 'javascript:' + encodeURIComponent(rawCode);

  var statBmBtn = document.getElementById('statBmBtn');
  var statCodeArea = document.getElementById('statCodeArea');
  if (statBmBtn) statBmBtn.href = bookmarkletHref;
  if (statCodeArea) statCodeArea.textContent = bookmarkletHref;

  var statThemeCodeArea = document.getElementById('statThemeCodeArea');
  if (statThemeCodeArea) statThemeCodeArea.textContent = themeCode;
}

function copyStatCode() {
  var rawCode = document.getElementById('rawStatBookmarklet').value.trim();
  var bookmarkletHref = 'javascript:' + encodeURIComponent(rawCode);
  navigator.clipboard.writeText(bookmarkletHref).then(function() {
    var msg = document.getElementById('statCopiedMsg');
    msg.style.opacity = '1';
    setTimeout(function() { msg.style.opacity = '0'; }, 2000);
  });
}

function copyStatThemeCode() {
  var code = document.getElementById('rawStatThemeCode').value.trim();
  navigator.clipboard.writeText(code).then(function() {
    var msg = document.getElementById('statThemeCopiedMsg');
    msg.style.opacity = '1';
    setTimeout(function() { msg.style.opacity = '0'; }, 2000);
  });
}

function switchStatTab(name, btn) {
  document.querySelectorAll('#tab-stat-theme, #tab-stat-bookmark').forEach(function(p) { p.classList.remove('active'); });
  btn.parentElement.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
}

function toggleStatManual(header) {
  var body = document.getElementById('statManualBody');
  var chevron = header.querySelector('.manual-chevron');
  body.classList.toggle('open');
  if (chevron) chevron.style.transform = body.classList.contains('open') ? 'rotate(180deg)' : '';
}

document.addEventListener('DOMContentLoaded', function() {
  setupInstructions();
  setupStatInstructions();
});
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ModuleStat — установка</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Mulish:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --ink: #0f0f0f;
  --muted: #6b6b6b;
  --faint: #f2f0eb;
  --accent: #1a4fd6;
  --accent-light: #e8eefb;
  --success: #1a7a4a;
  --success-light: #e6f4ed;
  --warn: #9a5a00;
  --warn-light: #fdf3e3;
  --border: #e0ddd6;
  --white: #ffffff;
}

body {
  font-family: 'Mulish', sans-serif;
  background: #faf9f6;
  color: var(--ink);
  line-height: 1.6;
  font-size: 16px;
  padding: 64px 32px 100px;
}

.page { max-width: 860px; margin: 0 auto; }

/* Header */
.header { margin-bottom: 48px; }
.logo {
  font-family: 'Syne', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 20px;
}
.logo span { color: var(--muted); font-weight: 400; }
h1 {
  font-family: 'Syne', sans-serif;
  font-size: 48px;
  font-weight: 800;
  line-height: 1.15;
  color: var(--ink);
  margin-bottom: 16px;
}
.subtitle {
  font-size: 18px;
  color: var(--muted);
  font-weight: 400;
  max-width: 560px;
}

/* What it does */
.features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 48px;
}
.feature {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px 18px;
}
.feature-icon { font-size: 20px; margin-bottom: 8px; }
.feature-title { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 600; margin-bottom: 4px; }
.feature-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }

/* Statuses preview */
.statuses {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 48px;
}
.statuses-title { font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; }
.status-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.status-row:last-child { margin-bottom: 0; }
.badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
  white-space: nowrap;
  min-width: 200px;
}
.badge-green { background: #EAF3DE; color: #27500A; }
.badge-purple { background: #EEEDFE; color: #3C3489; }
.badge-amber { background: #FAEEDA; color: #633806; }
.badge-blue { background: #E6F1FB; color: #0C447C; }
.badge-red { background: #FCEBEB; color: #791F1F; }
.status-desc { font-size: 12px; color: var(--muted); }

/* Install tabs */
.install-title {
  font-family: 'Syne', sans-serif;
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 8px;
}
.install-subtitle { font-size: 14px; color: var(--muted); margin-bottom: 28px; }

.tabs {
  display: flex;
  gap: 0;
  margin-bottom: 28px;
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}
.tab-btn {
  flex: 1;
  padding: 14px 20px;
  background: var(--faint);
  border: none;
  font-family: 'Syne', sans-serif;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  color: var(--muted);
  transition: background .15s, color .15s;
  text-align: center;
  border-right: 1px solid var(--border);
}
.tab-btn:last-child { border-right: none; }
.tab-btn.active {
  background: var(--white);
  color: var(--accent);
}
.tab-btn:hover:not(.active) { background: #ebe9e2; }

.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* Bookmark button */
.bookmark-wrap {
  background: var(--accent-light);
  border: 2px dashed #a0b8ef;
  border-radius: 16px;
  padding: 32px;
  text-align: center;
  margin-bottom: 32px;
}
.bookmark-label { font-size: 13px; color: var(--muted); margin-bottom: 16px; }
.bookmark-btn {
  display: inline-block;
  background: var(--accent);
  color: #fff;
  font-family: 'Syne', sans-serif;
  font-size: 15px;
  font-weight: 700;
  padding: 14px 28px;
  border-radius: 10px;
  text-decoration: none;
  cursor: grab;
  border: none;
  transition: transform .15s, box-shadow .15s;
  box-shadow: 0 4px 16px rgba(26,79,214,.25);
  user-select: none;
}
.bookmark-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,79,214,.3); }
.bookmark-btn:active { cursor: grabbing; transform: scale(.97); }
.bookmark-arrow { font-size: 12px; color: var(--muted); margin-top: 14px; display: flex; align-items: center; justify-content: center; gap: 6px; }
.bookmark-arrow svg { flex-shrink: 0; }

/* Steps */
.steps-label {
  font-family: 'Syne', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 16px;
}
.step {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  margin-bottom: 12px;
  padding: 16px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
}
.step-num {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--ink);
  color: #fff;
  font-family: 'Syne', sans-serif;
  font-size: 13px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.step-num.blue { background: var(--accent); }
.step-body { flex: 1; min-width: 0; }
.step-title { font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 600; margin-bottom: 4px; }
.step-desc { font-size: 13px; color: var(--muted); line-height: 1.5; }
.step-desc b { color: var(--ink); font-weight: 600; }
.step-desc code {
  background: var(--faint);
  padding: 1px 6px;
  border-radius: 4px;
  font-size: 12px;
  font-family: monospace;
}

/* Manual install */
.manual {
  margin-top: 20px;
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}
.manual-header {
  padding: 14px 18px;
  background: var(--faint);
  font-family: 'Syne', sans-serif;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  user-select: none;
}
.manual-header:hover { background: #ebe9e2; }
.manual-chevron { transition: transform .2s; }
.manual-body { display: none; padding: 18px; background: var(--white); }
.manual-body.open { display: block; }
.manual-body p { font-size: 13px; color: var(--muted); margin-bottom: 12px; }
.code-area {
  background: var(--faint);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 12px;
  font-family: monospace;
  font-size: 10px;
  line-height: 1.5;
  word-break: break-all;
  color: var(--ink);
  max-height: 100px;
  overflow-y: auto;
  margin-bottom: 10px;
}
.copy-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--white);
  font-family: 'Mulish', sans-serif;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  color: var(--ink);
  transition: background .15s;
}
.copy-btn:hover { background: var(--faint); }
.copied-msg { font-size: 12px; color: var(--success); margin-left: 8px; opacity: 0; transition: opacity .3s; }

/* Theme code block */
.theme-code-wrap {
  background: var(--faint);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 16px;
  margin: 12px 0;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}
.theme-code-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 8px;
}
.theme-code-area {
  background: #1e1e2e;
  color: #cdd6f4;
  border-radius: 8px;
  padding: 14px;
  font-family: monospace;
  font-size: 10px;
  line-height: 1.5;
  overflow: auto;
  max-height: 120px;
  margin-bottom: 10px;
  white-space: pre-wrap;
  word-break: break-all;
  width: 100%;
  box-sizing: border-box;
}

/* Note box */
.note {
  background: var(--warn-light);
  border: 1px solid #f0d5a0;
  border-left: 3px solid #e89c2a;
  border-radius: 0 8px 8px 0;
  padding: 12px 16px;
  font-size: 13px;
  color: var(--warn);
  line-height: 1.6;
  margin: 12px 0;
}
.note b { color: #7a4500; }

/* Usage */
.usage {
  margin-top: 48px;
  background: var(--success-light);
  border: 1px solid #b8dfc9;
  border-radius: 12px;
  padding: 20px 24px;
}
.usage-title { font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; color: var(--success); margin-bottom: 10px; }
.usage-step { font-size: 13px; color: #1a4a32; margin-bottom: 6px; display: flex; gap: 8px; }
.usage-step:last-child { margin-bottom: 0; }

@media (max-width: 600px) {
  body { padding: 32px 16px 60px; font-size: 15px; }
  h1 { font-size: 28px; }
  .subtitle { font-size: 15px; }
  .features { grid-template-columns: 1fr; }
  .tabs { flex-direction: column; }
  .tab-btn { border-right: none; border-bottom: 1px solid var(--border); }
  .tab-btn:last-child { border-bottom: none; }
  .badge { min-width: 160px; font-size: 10px; }
  .status-row { flex-wrap: wrap; gap: 6px; }
}
</style>
</head>
<body>

<!-- ХРАНИЛИЩЕ ЧИСТОГО JS-КОДА (без URL-кодирования) -->
<textarea id="rawBookmarklet" style="display:none;">(function(){
  if(location.href.indexOf('/teach/control/stat/stream/id/')===-1){alert('Откройте страницу Ученики модуля в GetCourse');return;}
  var m=location.href.match(/\/id\/(\d+)/);
  if(!m)return;
  var tid=m[1];
  var rows=document.querySelectorAll('tr.user-tr');
  if(!rows.length){alert('Строки учеников не найдены');return;}
  var thead=document.querySelector('tr:not(.user-tr)');
  var ths=thead?thead.querySelectorAll('th'):[];
  var visitedIdx=-1,answeredIdx=-1,lastVisitIdx=-1,statusIdx=-1;
  ths.forEach(function(th,i){var t=th.textContent.replace(/\s+/g,' ').trim();if(t.indexOf('Посетил')!==-1)visitedIdx=i;if(t.indexOf('Ответ')!==-1)answeredIdx=i;if(t.indexOf('Последн')!==-1)lastVisitIdx=i;if(t==='Статус')statusIdx=i;});
  if(lastVisitIdx===-1&&statusIdx!==-1&&statusIdx+1<ths.length){var nxt=ths[statusIdx+1];if(!nxt.className||nxt.className.indexOf('gc-pct')===-1)lastVisitIdx=statusIdx+1;}
  if(visitedIdx===-1||answeredIdx===-1){alert('Не найдены колонки "Посетил уроков" и "Ответы". Проверьте страницу.');return;}
  var statusEl=document.createElement('div');
  statusEl.style.cssText='position:fixed;top:16px;right:16px;z-index:99999;background:#185FA5;color:#fff;padding:10px 18px;border-radius:8px;font-size:14px;font-family:sans-serif;box-shadow:0 2px 12px rgba(0,0,0,.2)';
  statusEl.textContent='⏳ Считаю уроки модуля...';
  document.body.appendChild(statusEl);
  fetch('/teach/control/stream/view/id/'+tid,{credentials:'include'}).then(function(r){return r.text();}).then(function(html){
    var doc=(new DOMParser()).parseFromString(html,'text/html');
    var lessonCount=doc.querySelectorAll('ul.lesson-list li').length;
    var hwCount=doc.querySelectorAll('ul.lesson-list li.user-state-has_mission,ul.lesson-list li.user-state-need_accomplish,ul.lesson-list li.user-state-answered,ul.lesson-list li.user-state-accomplished').length;
    if(lessonCount===0){
      statusEl.style.background='#A32D2D';
      statusEl.textContent='❌ Не удалось определить уроки. Введите вручную.';
      var n=prompt('Сколько уроков в этом модуле?');
      lessonCount=parseInt(n)||1;
      var h=prompt('Сколько из них с домашним заданием?');
      hwCount=parseInt(h)||0;
    } else {
      statusEl.textContent='✓ Уроков: '+lessonCount+(hwCount>0?' · ДЗ: '+hwCount:'');
    }
    applyStats(lessonCount,hwCount);
    setTimeout(function(){statusEl.remove();},4000);
  }).catch(function(){
    statusEl.style.background='#A32D2D';
    statusEl.textContent='❌ Ошибка загрузки. Введите вручную.';
    var n=prompt('Сколько уроков в этом модуле?');
    var h=prompt('Сколько из них с домашним заданием?');
    applyStats(parseInt(n)||1,parseInt(h)||0);
    setTimeout(function(){statusEl.remove();},2000);
  });
  function parseGcDate(str){
    if(!str)return null;
    str=str.replace(/\s+/g,' ').trim().toLowerCase();
    if(str==='сегодня')return new Date();
    if(str==='вчера'){var d=new Date();d.setDate(d.getDate()-1);return d;}
    var months={'янв':0,'фев':1,'мар':2,'апр':3,'май':4,'мая':4,'июн':5,'июл':6,'авг':7,'сен':8,'окт':9,'ноя':10,'дек':11};
    var mDaysAgo=str.match(/(\d+)\s*дн/);
    if(mDaysAgo){var d=new Date();d.setDate(d.getDate()-parseInt(mDaysAgo[1]));return d;}
    var mDot=str.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})/);
    if(mDot)return new Date(parseInt(mDot[3]),parseInt(mDot[2])-1,parseInt(mDot[1]));
    var mRuFull=str.match(/^(\d{1,2})\s+([а-я]+)\s+(\d{4})/);
    if(mRuFull&&months[mRuFull[2].slice(0,3)]!==undefined)return new Date(parseInt(mRuFull[3]),months[mRuFull[2].slice(0,3)],parseInt(mRuFull[1]));
    var mWd=str.match(/^[а-я]{2}\s+(\d{1,2})\s+([а-я]+)(?:\s+(\d{4}))?/);
    if(mWd&&months[mWd[2].slice(0,3)]!==undefined){if(mWd[3])return new Date(parseInt(mWd[3]),months[mWd[2].slice(0,3)],parseInt(mWd[1]));var now=new Date();var yr=now.getFullYear();var d=new Date(yr,months[mWd[2].slice(0,3)],parseInt(mWd[1]));if(d>now)d.setFullYear(yr-1);return d;}
    var parsed=new Date(str);
    return isNaN(parsed)?null:parsed;
  }
  function daysSince(date){
    if(!date)return null;
    var diff=Date.now()-date.getTime();
    return Math.floor(diff/(1000*60*60*24));
  }
  function getStatus(row){
    var tds=row.querySelectorAll('td');
    var statuses=['Завершен','Завершён','Начат','Не начат'];
    for(var i=0;i<tds.length;i++){
      var t=tds[i].textContent.replace(/\s+/g,' ').trim();
      for(var j=0;j<statuses.length;j++){if(t===statuses[j])return t;}
    }
    return '';
  }
  function applyStats(maxLessons,hwCount){
    var table=rows[0].closest('table');
    var thead2=table.querySelector('thead tr');
    if(!thead2.querySelector('th.gc-pct')){
      ['Просмотрено','Сдано ДЗ','Отставание','Статус','Не заходил (дн.)'].forEach(function(t){
        var th=document.createElement('th');
        th.textContent=t;
        th.className='gc-pct';
        th.style.cssText='text-align:center;white-space:nowrap;padding:4px 8px;font-size:13px;';
        thead2.appendChild(th);
      });
    }
    rows.forEach(function(row){
      if(row.querySelector('td.gc-pct'))return;
      var tds=row.querySelectorAll('td');if(tds.length<4)return;
      var visited=parseInt(tds[visitedIdx].textContent.trim())||0;
      var answered=parseInt(tds[answeredIdx].textContent.trim())||0;
      var gcStatus=getStatus(row);
      var isCompleted=gcStatus.indexOf('Завершен')!==-1||gcStatus.indexOf('Завершён')!==-1;
      var visitedShow=isCompleted?maxLessons:Math.min(visited,maxLessons);
      var answeredShow=hwCount>0?(isCompleted?hwCount:Math.min(answered,hwCount)):0;
      var gap=isCompleted?0:(visited===0?0:(hwCount>0?Math.max(0,hwCount-answered):0));
      var pV=Math.round(visitedShow*100/maxLessons);
      var pA=hwCount>0?Math.round(answeredShow*100/hwCount):null;
      var days=null;
      if(lastVisitIdx!==-1&&tds[lastVisitIdx]){days=daysSince(parseGcDate(tds[lastVisitIdx].textContent));}
      function bar(pct,col){
        var c=col||(pct>=80?'#3B6D11':pct>=40?'#BA7517':'#A32D2D');
        return '<span style="display:inline-block;width:52px;height:7px;background:#ddd;border-radius:4px;vertical-align:middle;margin-right:4px"><span style="display:block;width:'+pct+'%;height:100%;background:'+c+';border-radius:4px"></span></span>';
      }
      var status,badge;
      if(isCompleted){status='✓ завершён';badge='background:#EAF3DE;color:#27500A';}
      else if(visited===0){status='не начал';badge='background:#FCEBEB;color:#791F1F';}
      else if(pV===100&&hwCount>0&&pA<100){status='Уроки пройдены, ДЗ не закрыто';badge='background:#EEEDFE;color:#3C3489';}
      else if(gap>0){status='ДЗ отстаёт от просмотров';badge='background:#FAEEDA;color:#633806';}
      else{status='в процессе';badge='background:#E6F1FB;color:#0C447C';}
      var gapColor=gap>=3?'#A32D2D':gap>=1?'#BA7517':'#3B6D11';
      var gapStr=hwCount>0?(gap>0?'<span style="color:'+gapColor+';font-weight:500">-'+gap+'</span>':'<span style="color:#3B6D11">0</span>'):'<span style="color:#888">—</span>';
      var pAcell=hwCount>0?(bar(pA,'#185FA5')+'<span style="font-size:12px">'+pA+'%</span>'):'<span style="color:#888;font-size:12px">нет ДЗ</span>';
      var daysColor=days===null?'#888':(days>=5?'#A32D2D':'#3B6D11');
      var daysStr=days===null?'<span style="color:#888;font-size:12px">—</span>':(days>=5?'<span style="color:#A32D2D;font-weight:700;font-size:12px">'+days+' дн. ⚠</span>':'<span style="color:#3B6D11;font-size:12px">'+days+' дн.</span>');
      row.dataset.gcDays=days!==null?String(days):'';
      [
        '<td class="gc-pct" style="text-align:center;padding:4px 8px">'+bar(pV)+'<span style="font-size:12px">'+pV+'%</span></td>',
        '<td class="gc-pct" style="text-align:center;padding:4px 8px">'+pAcell+'</td>',
        '<td class="gc-pct" style="text-align:center;padding:4px 8px;font-size:13px">'+gapStr+'</td>',
        '<td class="gc-pct" style="text-align:center;padding:4px 8px"><span style="padding:2px 9px;border-radius:10px;font-size:11px;white-space:nowrap;'+badge+'">'+status+'</span></td>',
        '<td class="gc-pct" style="text-align:center;padding:4px 8px">'+daysStr+'</td>'
      ].forEach(function(h){
        var tmp=document.createElement('tbody');
        tmp.innerHTML='<tr>'+h+'</tr>';
        row.appendChild(tmp.querySelector('td'));
      });
    });
    (function(){
      var allThs=thead2.querySelectorAll('th.gc-pct');
      var daysTh=allThs[allThs.length-1];
      if(!daysTh)return;
      var sortAsc=false;
      daysTh.style.cursor='pointer';
      daysTh.title='Нажмите для сортировки';
      daysTh.innerHTML='Не заходил (дн.) <span style="font-size:10px">▼</span>';
      daysTh.addEventListener('click',function(){
        sortAsc=!sortAsc;
        daysTh.innerHTML='Не заходил (дн.) <span style="font-size:10px">'+(sortAsc?'▲':'▼')+'</span>';
        var tbody=table.querySelector('tbody')||table;
        var allRows=Array.prototype.slice.call(tbody.querySelectorAll('tr.user-tr'));
        allRows.sort(function(a,b){
          var va=a.dataset.gcDays===''?null:parseInt(a.dataset.gcDays);
          var vb=b.dataset.gcDays===''?null:parseInt(b.dataset.gcDays);
          if(va===null&&vb===null)return 0;
          if(va===null)return 1;
          if(vb===null)return -1;
          return sortAsc?va-vb:vb-va;
        });
        allRows.forEach(function(r){tbody.appendChild(r);});
      });
    })();
    var old=document.getElementById('gc-csv-btn');if(old)old.remove();
    var btn=document.createElement('button');btn.id='gc-csv-btn';
    btn.innerHTML='Скачать CSV';
    btn.style.cssText='margin:12px 0;padding:8px 18px;background:#185FA5;color:#fff;border:none;border-radius:6px;font-size:14px;cursor:pointer;font-family:sans-serif;';
    btn.onclick=function(){
      var lines=[['Имя','Ссылка','Посетил уроков','% просмотров','Сдано ДЗ','% ДЗ','Отставание (ДЗ)','Статус','Всего уроков','Уроков с ДЗ','Не заходил (дн.)']];
      rows.forEach(function(row){
